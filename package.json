{
  "name": "psychosismeter",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test",
    "deploy": "pnpm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply psychosismeter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply psychosismeter-db --remote",
    "db:push": "drizzle-kit push",
    "db:push:remote": "DB_REMOTE=true drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "DB_REMOTE=true drizzle-kit studio",
    "debug:algo": "npx tsx scripts/debug-algorithm.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@orpc/client": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/tanstack-query": "^1.13.13",
    "@orpc/zod": "^1.13.13",
    "@takumi-rs/image-response": "1.0.0-beta.20",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-start": "1.167.12",
    "better-auth": "^1.5.6",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "1.7.0",
    "nanoid": "5.1.7",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.30.1",
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vite-plus": "0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14",
    "wrangler": "4.77.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
    }
  }
}
